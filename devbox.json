{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": {
    "path:nix/llvm-mlir#default": "",
    "z3": {
      "version": "4.16.0",
      "outputs": [
        "out",
        "lib",
        "dev"
      ]
    },
    "python312": "3.12.13",
    "nodejs_22": "22.23.1",
    "pkg-config": "0.29.2",
    "just": "1.55.1",
    "libxml2": {
      "version": "2.15.3",
      "outputs": [
        "out",
        "dev"
      ]
    },
    "zlib": {
      "version": "1.3.2",
      "outputs": [
        "out",
        "dev"
      ]
    },
    "sccache": "0.16.0",
    "cargo-nextest": "0.9.140"
  },
  "shell": {
    "init_hook": [
      ". ./scripts/devbox-init-env.sh"
    ],
    "scripts": {
      "coverage": [
        "./scripts/coverage.sh"
      ],
      "release": [
        "./scripts/release.sh"
      ],
      "lsp-vscode-build": [
        "cargo build --release -p quon_lsp -p quonfmt"
      ]
    }
  }
}
