-- RUN: %quonc %s --target %S/../../../targets/neutral_atom/generic_rna_v0.json --emit-na-mlir - --quiet | %FileCheck %s
--
-- Rydberg-spacing regression: two disjoint CNOTs land in one entangling
-- layer. The zoned placer must keep the simultaneous pairs at least
-- min_rydberg_spacing_um (18.75 um) apart — adjacent pair columns are only
-- 10-12 um apart, so naive nearest-pair assignment fails the dialect's R3
-- verifier. Placed correctly, the pairs sit at x = 0/2 and x = 24/26.

fn two_bells(): Circuit<4, 4, 4, Clifford> = circuit {
        H @0 |> H @2 |> CNOT @(0, 1) |> CNOT @(2, 3)
}

fn par_na(): Q<List<Bit>> = run {
        q <- (two_bells()) @ (qreg 4)
        measure_all q
}

-- CHECK: "quantum.na.schedule"()
--
-- One movement stage brings all four atoms in.
-- CHECK: "quantum.na.transfer"()
-- CHECK-SAME: direction = "slm_to_aod"
-- CHECK: "quantum.na.move"()
-- CHECK: "quantum.na.transfer"()
-- CHECK-SAME: direction = "aod_to_slm"
--
-- Both gates fire in the same Rydberg layer, on pairs 22 um apart.
-- CHECK: "quantum.na.entangle"()
-- CHECK-SAME: x_um\22:0.0
-- CHECK: "quantum.na.entangle"()
-- CHECK-SAME: x_um\22:24.0
-- CHECK: cycle = 3 : i64
--
-- CHECK: min_rydberg_spacing_um = 1.875000e+01
-- CHECK-SAME: target_id = "generic_reconfigurable_neutral_atom_v0"
