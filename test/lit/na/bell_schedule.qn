-- RUN: %quonc %s --target %S/../../../targets/neutral_atom/generic_rna_v0.json --emit-na-schedule - --quiet | %FileCheck %s
--
-- Neutral-atom Bell schedule JSON FileCheck (#112). Schedule JSON is the
-- debug/visualization view (ADR-0011); the canonical quantum.na MLIR emit
-- is covered by bell_na_mlir.qn / ising_na_mlir.qn (#167).

fn bell_state(): Circuit<2, 2, 2, Clifford> = circuit {
        H @0 |> CNOT @(0, 1)
}

fn bell_na(): Q<(Bit, Bit)> = run {
        (q0, q1) <- (bell_state()) @ (qreg 2)
        b0 <- measure q0
        b1 <- measure q1
        return (b0, b1)
}

-- CHECK: "kind"
-- CHECK: "na_schedule_view"
-- CHECK: "schema_version"
-- CHECK: "layers"
-- CHECK: "cycle"
-- CHECK: "Entangle2"
-- CHECK: "atoms"
