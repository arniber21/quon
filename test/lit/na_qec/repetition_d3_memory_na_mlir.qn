-- RUN: %quonc %s --target %S/../../../targets/neutral_atom/generic_rna_v0.json --emit-na-mlir - --quiet | %FileCheck %s
--
-- Repetition d=3 memory → quantum.na (#248 / ADR-0016): data+check atoms,
-- CZ entangles, check measure/reset across two memory rounds, then logical
-- data measure.

fn repetition_d3_memory(): Q<Bit> = run {
        b <- repetition_code<3>()
        b <- memory_round(b)
        b <- memory_round(b)
        measure_logical_z(b)
}

-- CHECK: "quantum.na.schedule"()
-- CHECK: "quantum.na.entangle"()
-- CHECK: "quantum.na.measure"{{.*}}atom = 1
-- CHECK: "quantum.na.measure"{{.*}}atom = 3
-- CHECK: "quantum.na.reset"{{.*}}atom = 1
-- CHECK: "quantum.na.reset"{{.*}}atom = 3
-- CHECK: "quantum.na.entangle"()
-- CHECK: "quantum.na.measure"{{.*}}atom = 1
-- CHECK: "quantum.na.measure"{{.*}}atom = 3
-- CHECK: "quantum.na.reset"{{.*}}atom = 1
-- CHECK: "quantum.na.reset"{{.*}}atom = 3
-- CHECK: "quantum.na.measure"{{.*}}atom = 0
-- CHECK: "quantum.na.measure"{{.*}}atom = 2
-- CHECK: "quantum.na.measure"{{.*}}atom = 4
-- CHECK: target_id = "generic_reconfigurable_neutral_atom_v0"
