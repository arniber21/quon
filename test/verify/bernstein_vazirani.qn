-- Bernstein-Vazirani entry point for end-to-end emission + Aer verification
-- (#29). Monomorphized for the secret string s = 110 (q0=1, q1=1, q2=0) over
-- n=3 query qubits plus one ancilla; a single shot recovers s exactly.
--
-- The oracle for s applies CNOT(q_i, anc) for each i with s_i = 1 (here i=0,1).
-- Parametric `hadamard_all(n)`, `tensored`/`split`, and circuit-valued oracles
-- from the general algorithm are flattened into one concrete circuit.

fn bv_oracle_s110(): Circuit<4, 4, 10, Clifford> = circuit {
    X @3
    |> H @0 |> H @1 |> H @2 |> H @3
    |> CNOT @(0, 3) |> CNOT @(1, 3)
    |> H @0 |> H @1 |> H @2
}

fn main(): Q<(Bit, Bit, Bit, Bit)> = run {
    (q0, q1, q2, anc) <- bv_oracle_s110() @ qreg(4)
    b0  <- measure(q0)
    b1  <- measure(q1)
    b2  <- measure(q2)
    anc_bit <- measure(anc)
    return (b0, b1, b2, anc_bit)
    -- Single shot: (b0, b1, b2) = (1, 1, 0) = secret s
}
