-- Teleportation oracle for the |+> message state (#29).
--
-- This complements teleport.qn's |1> case: |1> catches a broken X correction,
-- while |+> measured in the X basis catches a broken Z correction.

fn prep_plus(): Circuit<3, 3, 3, Clifford> = circuit { H @0 |> H @1 |> CNOT @(1, 2) }
fn bell_basis(): Circuit<2, 2, 2, Clifford> = circuit { CNOT @(0, 1) |> H @0 }
fn pauli_x(): Circuit<1, 1, 1, Clifford> = circuit { X @0 }
fn pauli_z(): Circuit<1, 1, 1, Clifford> = circuit { Z @0 }
fn hadamard(): Circuit<1, 1, 1, Clifford> = circuit { H @0 }
fn id_one(): Circuit<1, 1, 1, Clifford> = circuit { I @0 }

fn main(): Q<Bit> = run {
    (msg, alice, bob) <- prep_plus() @ qreg(3)
    (m2, a2)          <- bell_basis() @ (msg, alice)
    x_bit             <- measure(m2)
    z_bit             <- measure(a2)
    b2                <- (if z_bit then pauli_x() else id_one()) @ bob
    b3                <- (if x_bit then pauli_z() else id_one()) @ b2
    x_basis           <- hadamard() @ b3
    result            <- measure(x_basis)
    return result
}
