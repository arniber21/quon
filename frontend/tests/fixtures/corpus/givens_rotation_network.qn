fn givens_sweep(n: Nat, theta: Float): Circuit<n, n, n - 1, Universal> = circuit {
        (for i in (range(n - 1)) { (Ryy theta) @(i, i + 1) })
}

fn givens_network(n: Nat, theta: Float): Circuit<n, n, n * n, Universal> = match n {
0 => identity 0,
_ => givens_sweep(n, theta) |> on_low(givens_network(n - 1, theta), n)
}

fn run_givens(n: Nat, theta: Float): Q<List<Bit>> = run {
        q <- (givens_network(n, theta)) @ (qreg n)
        measure_all q
}
