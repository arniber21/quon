fn load_level(n: Nat): Circuit<n, n, n - 1, Universal> = circuit {
        (for i in (range(n - 1)) { (CRz(PI / 5.0)) @(0, i + 1) })
}

fn tree_loader(n: Nat): Circuit<n, n, n * n, Universal> = match n {
0 => identity 0,
_ => load_level n |> on_high(tree_loader(n - 1), n)
}

fn run_loader(n: Nat): Q<List<Bit>> = run {
        q <- (tree_loader n) @ (qreg n)
        measure_all q
}
