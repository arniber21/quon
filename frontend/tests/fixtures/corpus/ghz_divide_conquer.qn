fn entangle_one(n: Nat): Circuit<n, n, 1, Clifford> = circuit {
        CNOT @(0, n - 1)
}

fn ghz_dc(n: Nat): Circuit<n, n, n, Clifford> = match n {
0 => identity 0,
_ => on_low(ghz_dc(n - 1), n) |> entangle_one n
}

fn make_ghz_dc(n: Nat): Q<List<Bit>> = run {
        q <- (ghz_dc n) @ (qreg n)
        measure_all q
}
