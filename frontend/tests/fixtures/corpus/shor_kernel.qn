-- Shor order-finding kernel: prepare the control register, apply modular exponentiation against
-- a target, then the inverse QFT and measure.
-- Stresses: tensored registers, split, modular exponentiation by `repeat`, and the recursive QFT.

fn apply_hadamard(n: Nat): Circuit<n, n, 1, Clifford> = circuit { H @0 }

fn controlled_rotations(n: Nat): Circuit<n, n, 2 * (n - 1), Universal> = circuit {
    for i in range(n - 1) { controlled(Rz(PI / 4.0)) @(0, i + 1) }
}

fn qft(n: Nat): Circuit<n, n, 2 * n * n, Universal> =
    match n {
        0 => identity(0),
        _ => apply_hadamard(n)
             |> controlled_rotations(n)
             |> (qft(n - 1) `on_high` n)
             |> swap_reverse(n)
    }

fn hadamard_all(n: Nat): Circuit<n, n, 1, Clifford> = circuit {
    for q in qubits(n) { H q }
}

fn init_one(n: Nat): Circuit<n, n, 1, Clifford> = circuit { X @0 }

fn modular_mult(n: Nat, a: Int): Circuit<2*n, 2*n, 2*n, Universal> = circuit {
    for i in range(n) { controlled(Rz(PI / 4.0)) @(0, n + i) }
}

fn modexp(n: Nat, a: Int): Circuit<2*n, 2*n, 2*n*n, Universal> =
    repeat(n, modular_mult(n, a))

fn order_find(n: Nat, a: Int): Q<List<Bit>> = run {
    ctrl          <- hadamard_all(n) @ qreg(n)
    tgt           <- init_one(n) @ qreg(n)
    both          <- modexp(n, a) @ (ctrl `tensored` tgt)
    let (c2, _)    = split(n, both)
    est           <- adjoint(qft(n)) @ c2
    measure_all(est)
}
