-- QAOA for Minimum Vertex Cover: edge-penalty + vertex-count objective.
-- Stresses: penalty-scaled two-body terms plus a uniform single-body cost, depth p*(n*n+2).

fn hadamard_all(n: Nat): Circuit<n, n, 1, Clifford> = circuit {
    for q in qubits(n) { H q }
}

fn cover_cost(n: Nat, gamma: Float, penalty: Float, e: Matrix<n, n, Float>)
    : Circuit<n, n, n*n + 1, Universal> = circuit {
    for (i, j) in pairs(n) { Rzz(gamma * penalty * e[i][j]) @(i, j) }
    |> for i in diag(n)    { Rz(gamma) @i }
}

fn cover_mixer(n: Nat, beta: Float): Circuit<n, n, 1, Universal> = circuit {
    for q in qubits(n) { Rx(2.0 * beta) q }
}

fn cover_layer(n: Nat, gamma: Float, beta: Float, penalty: Float, e: Matrix<n, n, Float>)
    : Circuit<n, n, n*n + 2, Universal> = circuit {
    cover_cost(n, gamma, penalty, e) |> cover_mixer(n, beta)
}

fn cover_qaoa(n: Nat, p: Int, penalty: Float, params: List<(Float, Float)>, e: Matrix<n, n, Float>)
    : Circuit<n, n, p * (n*n + 2), Universal> =
    fold(take(p, params), identity(n), fn(acc, (gamma, beta)) ->
        acc |> cover_layer(n, gamma, beta, penalty, e)
    )

fn cover_shot(n: Nat, p: Int, penalty: Float, params: List<(Float, Float)>, e: Matrix<n, n, Float>)
    : Q<List<Bit>> = run {
    let circ = hadamard_all(n) |> cover_qaoa(n, p, penalty, params, e)
    reg     <- circ @ qreg(n)
    measure_all(reg)
}
