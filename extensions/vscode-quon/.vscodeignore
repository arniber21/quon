.vscode-test/**
.vscode/**
# Do NOT ignore all of node_modules — vsce already omits devDependencies.
# Excluding production deps (esp. vscode-languageclient) makes activate() fail
# to load, so commands/LSP never register while TextMate highlighting still works.
src/**
test/**
out/test/**
**/*.ts
!**/*.d.ts
**/*.map
tsconfig.json
.gitignore
.vscodeignore
scripts/**
dist/**
*.vsix
